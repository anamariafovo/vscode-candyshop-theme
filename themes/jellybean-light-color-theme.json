{
  "$schema": "vscode://schemas/color-theme",
  "name": "Jellybean Light",
  "type": "light",

  "_palette": {
    "bg0":       "#f0eef8",
    "bg1":       "#e8e4f4",
    "bg2":       "#ddd8f0",
    "bg3":       "#cec8e8",
    "bg4":       "#bfb8de",
    "border":    "#b0a8d4",
    "comment":   "#706888",
    "muted":     "#807898",
    "fg":        "#1a1b2e",
    "fgDim":     "#3a3c58",

    "yellow":    "#C9A000",
    "yellowDim": "#A88400",
    "orange":    "#CC6600",
    "orangeDim": "#A85200",
    "purple":    "#7C3AED",
    "purpleDim": "#6025CC",
    "teal":      "#0F9C8A",
    "tealDim":   "#0A7D6E",
    "green":     "#16A34A",
    "greenDim":  "#0F7A38",
    "red":       "#DC2626",
    "blue":      "#2563EB",
    "pink":      "#DB2777"
  },

  "colors": {
