    "editorWarning.foreground":              "#C9A000",
    "editorInfo.foreground":                 "#2563EB",
    "editorHint.foreground":                 "#16A34A",
    "editorOverviewRuler.border":            "#f0eef8",
    "editorOverviewRuler.addedForeground":   "#0F7A38",
    "editorOverviewRuler.deletedForeground": "#DC2626",
    "editorOverviewRuler.modifiedForeground":"#2563EB",
    "editorOverviewRuler.errorForeground":   "#DC2626",
    "editorOverviewRuler.warningForeground": "#C9A000",
    "editorOverviewRuler.findMatchForeground":"#C9A000",
    "editorOverviewRuler.selectionHighlightForeground":"#7C3AED",

    "activityBar.background":               "#f0eef8",
    "activityBar.foreground":               "#1a1b2e",
    "activityBar.inactiveForeground":       "#bfb8de",
    "activityBar.border":                   "#e8e4f4",
    "activityBarBadge.background":          "#CC6600",
    "activityBarBadge.foreground":          "#ffffff",

    "sideBar.background":                   "#e8e4f4",
    "sideBar.foreground":                   "#1a1b2e",
    "sideBar.border":                       "#ddd8f0",
    "sideBarTitle.foreground":              "#706888",
