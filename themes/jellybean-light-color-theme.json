    "editorCursor.foreground":               "#7C3AED",
    "editorLineNumber.foreground":           "#bfb8de",
    "editorLineNumber.activeForeground":     "#807898",
    "editorIndentGuide.background1":         "#ddd8f0",
    "editorIndentGuide.activeBackground1":   "#b0a8d4",
    "editorWhitespace.foreground":           "#b0a8d4",
    "editorBracketMatch.background":         "#0F9C8A20",
    "editorBracketMatch.border":             "#0F9C8A80",
