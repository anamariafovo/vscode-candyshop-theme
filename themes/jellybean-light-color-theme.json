    "statusBar.debuggingForeground":        "#ffffff",
    "statusBarItem.remoteBackground":       "#7C3AED",
    "statusBarItem.remoteForeground":       "#ffffff",
    "statusBarItem.hoverBackground":        "#ddd8f0",

    "titleBar.activeBackground":            "#f0eef8",
    "titleBar.activeForeground":            "#807898",
    "titleBar.inactiveBackground":          "#f0eef8",
    "titleBar.inactiveForeground":          "#bfb8de",
    "titleBar.border":                      "#e8e4f4",

    "tab.activeBackground":                 "#f0eef8",
    "tab.activeForeground":                 "#1a1b2e",
    "tab.activeBorder":                     "#C9A000",
    "tab.inactiveBackground":               "#e8e4f4",
