    "editorGroupHeader.tabsBorder":         "#e8e4f4",

    "panel.background":                     "#f0eef8",
    "panel.border":                         "#ddd8f0",
    "panelTitle.activeBorder":              "#C9A000",
    "panelTitle.activeForeground":          "#1a1b2e",
    "panelTitle.inactiveForeground":        "#706888",

    "terminal.background":                  "#f0eef8",
    "terminal.foreground":                  "#1a1b2e",
    "terminal.ansiBlack":                   "#1a1b2e",
    "terminal.ansiBlue":                    "#2563EB",
    "terminal.ansiBrightBlack":             "#807898",
    "terminal.ansiBrightBlue":              "#5B8FEF",
    "terminal.ansiBrightCyan":              "#3ABFAD",
    "terminal.ansiBrightGreen":             "#4ADE80",
    "terminal.ansiBrightMagenta":           "#F472B6",
    "terminal.ansiBrightRed":               "#FCA5A5",
    "terminal.ansiBrightWhite":             "#1a1b2e",
    "terminal.ansiBrightYellow":            "#D4A800",
    "terminal.ansiCyan":                    "#0F9C8A",
    "terminal.ansiGreen":                   "#16A34A",
    "terminal.ansiMagenta":                 "#DB2777",
    "terminal.ansiRed":                     "#DC2626",
    "terminal.ansiWhite":                   "#3a3c58",
    "terminal.ansiYellow":                  "#C9A000",
    "terminal.selectionBackground":         "#7C3AED30",
    "terminalCursor.foreground":            "#7C3AED",

    "input.background":                     "#e8e4f4",
    "input.foreground":                     "#1a1b2e",
    "input.border":                         "#b0a8d4",
    "input.placeholderForeground":          "#706888",
    "inputOption.activeBorder":             "#C9A000",
    "inputOption.activeBackground":         "#C9A00020",
    "inputOption.activeForeground":         "#C9A000",
    "inputValidation.errorBackground":      "#DC262618",
    "inputValidation.errorBorder":          "#DC2626",
    "inputValidation.warningBackground":    "#C9A00018",
    "inputValidation.warningBorder":        "#C9A000",
    "inputValidation.infoBackground":       "#2563EB18",
    "inputValidation.infoBorder":           "#2563EB",

    "dropdown.background":                  "#e8e4f4",
    "dropdown.foreground":                  "#1a1b2e",
    "dropdown.border":                      "#b0a8d4",

    "button.background":                    "#7C3AED",
    "button.foreground":                    "#ffffff",
    "button.hoverBackground":               "#6025CC",
    "button.secondaryBackground":           "#cec8e8",
    "button.secondaryForeground":           "#1a1b2e",
    "button.secondaryHoverBackground":      "#bfb8de",

    "badge.background":                     "#CC6600",
    "badge.foreground":                     "#ffffff",

    "progressBar.background":               "#7C3AED",

    "scrollbar.shadow":                     "#b0a8d460",
    "scrollbarSlider.background":           "#b0a8d460",
    "scrollbarSlider.hoverBackground":      "#b0a8d490",
    "scrollbarSlider.activeBackground":     "#7C3AED40",

    "notifications.background":             "#e8e4f4",
    "notifications.foreground":             "#1a1b2e",
    "notifications.border":                 "#b0a8d4",
    "notificationLink.foreground":          "#CC6600",

    "focusBorder":                          "#7C3AED60",
    "foreground":                           "#1a1b2e",
    "descriptionForeground":                "#807898",
    "errorForeground":                      "#DC2626",
    "icon.foreground":                      "#807898",
    "widget.shadow":                        "#b0a8d480",
    "selection.background":                 "#7C3AED30",
    "textLink.foreground":                  "#CC6600",
    "textLink.activeForeground":            "#A85200",

    "gitDecoration.addedResourceForeground":        "#16A34A",
    "gitDecoration.deletedResourceForeground":      "#DC2626",
    "gitDecoration.modifiedResourceForeground":     "#2563EB",
    "gitDecoration.untrackedResourceForeground":    "#C9A000",
    "gitDecoration.ignoredResourceForeground":      "#bfb8de",
    "gitDecoration.conflictingResourceForeground":  "#DB2777",
    "gitDecoration.stageAddedResourceForeground":   "#16A34A",
    "gitDecoration.stageDeletedResourceForeground": "#DC2626",
    "gitDecoration.stageModifiedResourceForeground":"#2563EB",

    "peekView.border":                      "#7C3AED",
    "peekViewEditor.background":            "#e8e4f4",
    "peekViewEditor.matchHighlightBackground":"#C9A00030",
    "peekViewResult.background":            "#f0eef8",
    "peekViewResult.fileForeground":        "#1a1b2e",
    "peekViewResult.lineForeground":        "#807898",
    "peekViewResult.matchHighlightBackground":"#C9A00030",
    "peekViewResult.selectionBackground":   "#ddd8f0",
    "peekViewResult.selectionForeground":   "#1a1b2e",
    "peekViewTitle.background":             "#f0eef8",
    "peekViewTitleLabel.foreground":        "#1a1b2e",
    "peekViewTitleDescription.foreground":  "#807898",

    "diffEditor.insertedTextBackground":    "#16A34A15",
    "diffEditor.removedTextBackground":     "#DC262615",
    "diffEditor.insertedLineBackground":    "#16A34A10",
    "diffEditor.removedLineBackground":     "#DC262610",

    "debugToolBar.background":              "#e8e4f4",
    "debugIcon.breakpointForeground":       "#DC2626",
    "debugIcon.breakpointCurrentStackframeForeground": "#C9A000",
    "debugIcon.startForeground":            "#16A34A",

    "breadcrumb.foreground":                "#706888",
    "breadcrumb.focusForeground":           "#1a1b2e",
    "breadcrumb.activeSelectionForeground": "#1a1b2e",
    "breadcrumbPicker.background":          "#e8e4f4",

    "menu.background":                      "#e8e4f4",
    "menu.foreground":                      "#1a1b2e",
    "menu.selectionBackground":             "#cec8e8",
    "menu.selectionForeground":             "#1a1b2e",
    "menu.separatorBackground":             "#b0a8d4",
    "menubar.selectionBackground":          "#ddd8f0",
    "menubar.selectionForeground":          "#1a1b2e",

    "charts.blue":                          "#2563EB",
    "charts.green":                         "#16A34A",
    "charts.yellow":                        "#C9A000",
    "charts.red":                           "#DC2626",
    "charts.orange":                        "#CC6600",
    "charts.purple":                        "#7C3AED",
    "charts.foreground":                    "#1a1b2e",
    "charts.lines":                         "#b0a8d4"
  },

  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#706888", "fontStyle": "italic" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#C9A000" }
    },
    {
      "name": "String escape / special characters",
      "scope": ["constant.character.escape", "string.regexp"],
      "settings": { "foreground": "#CC6600" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#DB2777" }
    },
    {
      "name": "Booleans / null / undefined",
      "scope": ["constant.language"],
      "settings": { "foreground": "#DB2777", "fontStyle": "italic" }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.of",
        "storage",
        "storage.type"
      ],
      "settings": { "foreground": "#2563EB" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator", "punctuation.separator"],
      "settings": { "foreground": "#807898" }
    },
    {
      "name": "Functions / methods",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function"
      ],
      "settings": { "foreground": "#16A34A" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#0F9C8A", "fontStyle": "italic" }
    },
    {
      "name": "Classes / types",
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": { "foreground": "#7C3AED" }
    },
    {
      "name": "Type annotations / generics",
      "scope": [
        "entity.name.type.alias",
        "entity.name.type.interface",
        "meta.type.annotation",
        "support.type"
      ],
      "settings": { "foreground": "#0F9C8A" }
    },
    {
      "name": "Decorators / annotations",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": { "foreground": "#CC6600" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#1a1b2e" }
    },
    {
      "name": "Object properties / member access",
      "scope": [
        "variable.other.object.property",
        "meta.object-literal.key",
        "support.variable.property"
      ],
      "settings": { "foreground": "#3a3c58" }
    },
    {
      "name": "Constants / enum members",
      "scope": ["variable.other.constant", "variable.other.enummember"],
      "settings": { "foreground": "#DB2777" }
    },
    {
      "name": "Modules / namespaces",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "variable.other.module"
      ],
      "settings": { "foreground": "#2563EB" }
    },
    {
      "name": "Import / export keywords",
      "scope": ["keyword.control.import", "keyword.control.export"],
      "settings": { "foreground": "#2563EB" }
    },
    {
      "name": "Imported name",
      "scope": ["variable.other.readwrite.alias"],
      "settings": { "foreground": "#1a1b2e" }
    },

    {
      "name": "HTML tags",
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#DB2777" }
    },
    {
      "name": "HTML attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#0F9C8A" }
    },
    {
      "name": "HTML attribute values",
      "scope": ["string.quoted.double.html", "string.quoted.single.html"],
      "settings": { "foreground": "#C9A000" }
    },
    {
      "name": "HTML / XML punctuation",
      "scope": [
        "punctuation.definition.tag",
        "meta.tag.sgml"
      ],
      "settings": { "foreground": "#706888" }
    },

    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": { "foreground": "#16A34A" }
    },
    {
      "name": "CSS properties",
      "scope": ["support.type.property-name.css"],
      "settings": { "foreground": "#2563EB" }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": { "foreground": "#C9A000" }
    },
    {
      "name": "CSS units",
      "scope": ["keyword.other.unit.css"],
      "settings": { "foreground": "#DB2777" }
    },
    {
      "name": "CSS at-rules",
      "scope": ["keyword.control.at-rule"],
      "settings": { "foreground": "#7C3AED" }
    },

    {
      "name": "JSON keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#2563EB" }
    },
    {
      "name": "JSON string values",
      "scope": ["string.quoted.double.json"],
      "settings": { "foreground": "#C9A000" }
    },
    {
      "name": "JSON boolean / null",
      "scope": ["constant.language.json"],
      "settings": { "foreground": "#DB2777", "fontStyle": "italic" }
    },

    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": { "foreground": "#2563EB", "fontStyle": "bold" }
    },
    {
      "name": "Markdown bold",
      "scope": ["markup.bold"],
      "settings": { "foreground": "#C9A000", "fontStyle": "bold" }
    },
    {
      "name": "Markdown italic",
      "scope": ["markup.italic"],
      "settings": { "foreground": "#DB2777", "fontStyle": "italic" }
    },
    {
      "name": "Markdown code",
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#16A34A" }
    },
    {
      "name": "Markdown link",
      "scope": ["string.other.link.title.markdown"],
      "settings": { "foreground": "#7C3AED" }
    },
    {
      "name": "Markdown link URL",
      "scope": ["markup.underline.link.markdown"],
      "settings": { "foreground": "#0F9C8A" }
    },
    {
      "name": "Markdown blockquote",
      "scope": ["markup.quote"],
      "settings": { "foreground": "#706888", "fontStyle": "italic" }
    },
    {
      "name": "Markdown list bullet",
      "scope": ["punctuation.definition.list.begin.markdown"],
      "settings": { "foreground": "#7C3AED" }
    },

    {
      "name": "Punctuation / brackets",
      "scope": [
        "punctuation.definition.block",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": { "foreground": "#807898" }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid"],
      "settings": { "foreground": "#DC2626", "fontStyle": "underline" }
    },
    {
      "name": "Diff added",
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#16A34A" }
    },
    {
      "name": "Diff removed",
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#DC2626" }
    },
    {
      "name": "Diff changed",
      "scope": ["markup.changed"],
      "settings": { "foreground": "#2563EB" }
    }
  ],

  "semanticHighlighting": true,
  "semanticTokenColors": {
    "namespace":         "#2563EB",
    "type":              "#0F9C8A",
    "class":             "#7C3AED",
    "interface":         "#0F9C8A",
    "typeParameter":     "#0F9C8A",
    "function":          "#16A34A",
    "method":            "#16A34A",
    "property":          "#3a3c58",
    "variable":          "#1a1b2e",
    "variable.constant": "#DB2777",
    "parameter":         { "foreground": "#0F9C8A", "italic": true },
    "enumMember":        "#DB2777",
    "decorator":         "#CC6600",
    "comment":           { "foreground": "#706888", "italic": true },
    "string":            "#C9A000",
    "number":            "#DB2777",
    "keyword":           "#2563EB",
    "operator":          "#807898",
    "macro":             "#CC6600",
    "label":             "#807898"
  }
}
